---
---

<section class="chat-shell" id="chat-shell" aria-label="Conneen AI workflow diagnostic chat">
  <div class="chat-panel">
    <header class="chat-header">
      <p class="eyebrow">AI pilot diagnostic</p>
      <h1>Find the workflow AI should fix first.</h1>
    </header>

    <div class="chat-log" id="chat-log">
      <div class="message assistant">
        I'm Conneen AI's workflow diagnostic assistant. Tell me one slow, repetitive, expensive, or error-prone process in your business. I'll help classify the opportunity, identify the likely tools/data involved, and shape it into a practical first pilot with human review where it matters.
      </div>
    </div>

    <form class="lead-capture" id="lead-capture-form" hidden>
      <div>
        <p class="lead-capture-title">Send this diagnostic to Conneen AI</p>
        <p class="lead-capture-copy">I can draft this from the diagnostic, or you can edit it before sending.</p>
      </div>
      <div class="lead-fields">
        <input id="lead-name" name="name" type="text" placeholder="Name" autocomplete="name" />
        <input id="lead-email" name="email" type="email" placeholder="Email" autocomplete="email" required />
        <input id="lead-company" name="company" type="text" placeholder="Company" autocomplete="organization" />
        <textarea
          id="lead-workflow"
          name="workflow"
          placeholder="Workflow brief, tools/data involved, likely pilot, and human review points..."
          required
        ></textarea>
        <div class="lead-actions">
          <button id="lead-draft-button" type="button">Draft from chat</button>
          <button id="lead-submit-button" type="submit">Send brief</button>
        </div>
      </div>
    </form>

    <form class="chat-form" id="chat-form">
      <textarea
        id="chat-input"
        name="message"
        placeholder="Example: We spend hours turning emails, calls, PDFs, or spreadsheets into quotes, reports, schedules, or task lists..."
        autocomplete="off"
        required
      ></textarea>
      <button id="send-button" type="submit">Analyze</button>
    </form>
  </div>

  <div class="lead-thanks-message" id="lead-thanks-message" aria-live="polite"></div>
</section>
