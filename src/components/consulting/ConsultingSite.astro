    <a class="brand-lockup site-brand" href="#top" aria-label="Conneen AI Consulting home">
      <img class="brand-logo-image" src="/assets/conneen-ai-logo.png" alt="Conneen AI Consulting" />
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#problems">Problems</a>
      <a href="#pilots">Pilots</a>
      <a href="#process">Process</a>
